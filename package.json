{
  "name": "github-command-center",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && vite build",
    "check": "npm run lint && npm run dead-code && npm run test && npm run build && npm run smoke:hosted",
    "clean": "rm -rf dist",
    "dead-code": "knip",
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:hosted": "node scripts/smoke-hosted.mjs",
    "start": "node --env-file-if-exists=.env server/main.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.app.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "private": true
}
