# ----- Local mode (npm run dev / npm run preview) -----
# Optional: override the GitHub CLI binary used by the local API middleware.
# Leave unset if `gh` is already on PATH.
# GH_BIN=/usr/local/bin/gh

# ----- Hosted mode (npm start) -----
# Create a GitHub OAuth App at https://github.com/settings/developers
# with the callback URL set to ${BASE_URL}/auth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# At least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public URL of the deployment (used for OAuth redirects and secure cookies).
BASE_URL=http://localhost:3000
PORT=3000

# Set to 1 when running behind a reverse proxy (nginx, Caddy, a PaaS load
# balancer) so per-client rate limits use X-Forwarded-For instead of the
# proxy's address. Leave unset if clients connect to Node directly.
# TRUST_PROXY=1
