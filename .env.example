# `npm start` loads this file automatically. Vite does not load these values
# into the Node process used by `npm run dev` or `npm run preview`; export local
# overrides in the shell that starts Vite instead:
#   GH_BIN=/usr/local/bin/gh npm run dev
#   GITHUB_COMMAND_CENTER_REPO_CACHE=/tmp/gcc-repo-details.json npm run dev

# ----- Local mode (shell export for npm run dev / npm run preview) -----
# GH_BIN=/usr/local/bin/gh
# GITHUB_COMMAND_CENTER_REPO_CACHE=.cache/github-command-center/repo-details.json

# ----- Standalone hosted mode (npm start / Docker) -----
# The public Cloudflare Worker is configured only through wrangler.jsonc and is
# intentionally OAuth-free. Do not copy this file or local gh credentials there.
# Public URL of the deployment.
BASE_URL=http://localhost:3000
PORT=3000

# Optional: server-side token used only for public profile REST requests.
# This keeps /username pages no-login for visitors while raising GitHub API limits.
# Hosted public dashboards fall back to GitHub's anonymous 60/hour IP quota
# when this is unset.
GITHUB_PUBLIC_TOKEN=

# Optional: enable GitHub OAuth sign-in for the root/private dashboard.
# Public profile routes like /jskoiz do not require these values.
# When public GitHub quota is exhausted, configured OAuth lets visitors sign in
# and retry with their own GitHub API quota.
# Create a GitHub OAuth App at https://github.com/settings/developers
# with the callback URL set to ${BASE_URL}/auth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Required only when OAuth is configured. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Set to 1 when running behind a reverse proxy (nginx, Caddy, a PaaS load
# balancer) so per-client rate limits use X-Forwarded-For instead of the
# proxy's address. Leave unset if clients connect to Node directly.
# TRUST_PROXY=1
